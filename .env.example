# ========================================
# Expense Reimbursement AI Agent — Configuration
# ========================================
# Copy: cp .env.example .env
# Git:   .env is IGNORED (never committed)

# --- DeepSeek LLM (required for real AI; omit for Mock mode) ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OCR Engine (easyocr | mock) ---
OCR_ENGINE=easyocr

# --- Knowledge Base ---
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_TOP_K=5
KB_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
KB_CHROMA_PATH=./data/chroma

# --- Agent ---
AGENT_MAX_RETRIES=2
AGENT_CLOUD_TIMEOUT_SECONDS=60

# --- Database ---
DATABASE_URL=sqlite:///./expense_reimbursement.db

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
APP_HOST=0.0.0.0
APP_PORT=8000

# --- File Storage ---
INVOICE_STORAGE_PATH=./data/invoices

# --- PII ---
PII_MAPPING_RETENTION_DAYS=7

